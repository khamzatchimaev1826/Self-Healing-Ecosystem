# Default: embedded local database (no Docker required)
USE_PGLITE=true
PGLITE_DATA_DIR=.local/pglite

# API server port (required)
PORT=5000
FRONTEND_PORT=3000
NODE_ENV=development

# Cloud Postgres (Neon/Render): set USE_PGLITE=false and use your connection string
# USE_PGLITE=false
# DATABASE_URL=postgresql://user:pass@host/db

# Docker Postgres alternative:
# USE_PGLITE=false
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ecosystem

# Production only — set in Vercel (your Render API URL, no trailing slash)
# VITE_API_URL=https://ecosystem-api.onrender.com
